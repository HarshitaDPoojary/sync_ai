# ── Recall.ai ────────────────────────────────────────────────────────────────
RECALL_API_KEY=your_recall_api_key
RECALL_BASE_URL=https://us-east-1.recall.ai/api/v1
RECALL_TRANSCRIPTION_PROVIDER=assembly_ai
RECALL_BOT_NAME=Meeting Copilot

# ── LLM ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.1-70b-versatile

# ── Embeddings ────────────────────────────────────────────────────────────────
HUGGINGFACE_API_KEY=your_huggingface_api_key
EMBEDDING_MODEL=thenlper/gte-large

# ── LangSmith ────────────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key
LANGCHAIN_PROJECT=sync_ai
LANGSMITH_SIGNAL_DATASET=sync_ai-signal-detection
LANGSMITH_EXTRACTION_DATASET=sync_ai-action-extraction

# ── Clerk Auth ────────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_FRONTEND_API=clerk.your-domain.com

# ── Slack OAuth ───────────────────────────────────────────────────────────────
SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret
SLACK_OAUTH_REDIRECT_URI=https://your-app.onrender.com/auth/slack/callback
# Legacy fallback (single-tenant mode only — remove once all users connect via OAuth)
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_CHANNEL_ID=C0XXXXXXXXX

# ── Google OAuth (Gmail + Calendar) ──────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_OAUTH_REDIRECT_URI=https://your-app.onrender.com/auth/google/callback

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=./data/sync_ai.db
CHROMA_PERSIST_DIR=./data/chroma

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
WEBHOOK_BASE_URL=https://your-app.onrender.com
RECALL_WEBHOOK_SECRET=whsec_your_recall_workspace_verification_secret
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info

# ── Calendar auto-join ────────────────────────────────────────────────────────
CALENDAR_POLL_INTERVAL_SECONDS=300
CALENDAR_BOT_DISPATCH_OFFSET_SECONDS=120

# ── Eval datasets (HuggingFace repos) ────────────────────────────────────────
AMI_DATASET_REPO=edinburghcristin/ami-corpus
MEETINGBANK_DATASET_REPO=huuuyeah/meetingbank
EVAL_FIXTURES_PATH=tests/eval/datasets/golden_transcripts.json

# ── Analysis tuning ──────────────────────────────────────────────────────────
ANALYSIS_TOKEN_THRESHOLD=500
ANALYSIS_WINDOW_SECONDS=300
EXTRACTION_CHECKPOINT_CHUNKS=50
